{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": true,
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "trailingComma": "es5",
  "arrowParens": "always",
  "endOfLine": "lf",
  "ignorePatterns": [
    "node_modules",
    "dist",
    "coverage",
    "pnpm-lock.yaml",
    "package-lock.json",
    "*.csv",
    "*.jsonl"
  ]
}
